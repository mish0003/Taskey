{% extends "projects/base.twig" %}

{% block content %}
    <form method="POST" action="/projects">
        <div class="card shadow-sm">
            <div class="card-header">
                <strong>Create New Project</strong>
            </div>
            <div class="card-body">

                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold"><label for="title">Title</label></div>
                    <div class="col-sm-9">
                        <input type="text" id="title" name="title" class="form-control" value="{{ project.title }}">
                        {% if errors.title %}<div class="invalid-feedback d-block">{{ errors.title }}</div>{% endif %}
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-sm-3 fw-bold"><label for="description">Description</label></div>
                    <div class="col-sm-9 text-break">
                        <textarea id="description" name="description" class="form-control">{{ project.description }}</textarea>
                        {% if errors.description %}<div class="invalid-feedback d-block">{{ errors.description }}</div>{% endif %}
                    </div>
                </div>
            </div>

            <div class="card-footer d-flex gap-2">
                <input type="submit" value="Create" class="btn btn-primary">
            </div>
        </div>
    </form>
{% endblock %}